#. Translators: message presented when feeds cannot be reported.
#: addon\globalPlugins\readFeeds\__init__.py:48
msgid "Unable to refresh feed. Check your Internet conectivity or that the specified feed address is correct."
msgstr "No es posible actualizar el feed. Comprueba tu conectividad a Internet o que la dirección de feeds especificada es correcta."

#. Translators: Message presented when feeds have been copied.
#: addon\globalPlugins\readFeeds\__init__.py:134
msgid "Feeds copied"
msgstr "Feeds copiados"

#. Translators: label of error dialog shown when cannot copy feeds folder.
#: addon\globalPlugins\readFeeds\__init__.py:140
#: addon\globalPlugins\readFeeds\__init__.py:161
msgid "Folder not copied"
msgstr "Carpeta no copiada"

#. Translators: title of error dialog shown when cannot copy feeds folder.
#: addon\globalPlugins\readFeeds\__init__.py:142
#: addon\globalPlugins\readFeeds\__init__.py:163
msgid "Copy Error"
msgstr "Error de copia"

#. Translators: Message presented when feeds have been restored.
#: addon\globalPlugins\readFeeds\__init__.py:155
msgid "Feeds restored"
msgstr "Feeds restaurados"

#. Translators: Title of a dialog.
#: addon\globalPlugins\readFeeds\__init__.py:185
#, python-brace-format
msgid "Feeds: {}"
msgstr "Feeds: {}"

#. Translators: Label of a dialog (message translated in NVDA's core in different contexts).
#: addon\globalPlugins\readFeeds\__init__.py:191
msgid "&Filter by:"
msgstr "&Filtrar por:"

#. Translators: The label of a button to open the list of articles of a feed.
#: addon\globalPlugins\readFeeds\__init__.py:219
msgid "List of &articles..."
msgstr "Lista de &artículos..."

#. Translators: The label of a button to open a feed.
#: addon\globalPlugins\readFeeds\__init__.py:235
msgid "&Open feed"
msgstr "&Abrir feed"

#. Translators: The label of a button to open a feed as HTML.
#: addon\globalPlugins\readFeeds\__init__.py:239
msgid "Open feed as &HTML"
msgstr "Abrir feed como &HTML"

#. Translators: The label of a button to copy the feed URL.
#: addon\globalPlugins\readFeeds\__init__.py:243
msgid "Cop&y feed address"
msgstr "Cop&iar dirección del feed"

#. Translators: The label of a button to add a new feed.
#: addon\globalPlugins\readFeeds\__init__.py:247
msgid "&New..."
msgstr "&Nuevo..."

#. Translators: The label of a button to rename a feed.
#: addon\globalPlugins\readFeeds\__init__.py:251
msgid "&Rename..."
msgstr "&Renombrar..."

#. Translators: The label of a button to delete a feed.
#: addon\globalPlugins\readFeeds\__init__.py:255
msgid "&Delete..."
msgstr "&Eliminar..."

#. Translators: The label of a button to set a feed as default.
#: addon\globalPlugins\readFeeds\__init__.py:259
msgid "S&et default"
msgstr "&Configurar como predeterminado"

#. Translators: The label of a button to import feeds from OPML.
#: addon\globalPlugins\readFeeds\__init__.py:263
msgid "&Import feeds from OPML file..."
msgstr "&Importar feeds desde archivo OPML..."

#. Translators: The label of a button to save feeds to OPML file.
#: addon\globalPlugins\readFeeds\__init__.py:267
msgid "&Save feeds to OPML file..."
msgstr "&Guardar feeds en archivo OPML..."

#. Translators: The label of a button to open the settings dialog for readFeeds.
#: addon\globalPlugins\readFeeds\__init__.py:271
msgid "&Preferences..."
msgstr "&Preferencias..."

#. Translators: Message presented when a feed cannot be added.
#: addon\globalPlugins\readFeeds\__init__.py:301
#, python-format
msgid "Cannot add feed: %s"
msgstr "No se puede añadir el feed: %s"

#. Translators: error message.
#: addon\globalPlugins\readFeeds\__init__.py:303
msgid "Error"
msgstr "Error"

#. Translators: the label of a message box dialog.
#: addon\globalPlugins\readFeeds\__init__.py:380
#, python-brace-format
msgid "Do you want to copy feed address to the clipboard?\n"
"{}"
msgstr "¿Quieres copiar la dirección del feed al portapapeles?\n"
"{}"

#. Translators: the title of a message box dialog.
#: addon\globalPlugins\readFeeds\__init__.py:383
msgid "Copy feed address"
msgstr "Copiar dirección del feed"

#. Translators: Label of a dialog.
#: addon\globalPlugins\readFeeds\__init__.py:394
msgid "Address of a new feed:"
msgstr "Dirección de un feed nuevo:"

#. Translators: The title of a dialog to create a new feed.
#: addon\globalPlugins\readFeeds\__init__.py:396
msgid "New feed"
msgstr "Feed nuevo"

#. Translators: The confirmation prompt displayed when the user requests to delete a feed.
#: addon\globalPlugins\readFeeds\__init__.py:414
msgid "Are you sure you want to delete this feed? This cannot be undone."
msgstr "¿Estás seguro de querer eliminar este feed? Esto no puede deshacerse."

#. Translators: The label of a field to enter a new name for a feed.
#: addon\globalPlugins\readFeeds\__init__.py:447
msgid "New name:"
msgstr "Nombre nuevo:"

#. Translators: The title of a dialog to rename a feed.
#: addon\globalPlugins\readFeeds\__init__.py:449
msgid "Rename feed"
msgstr "Renombrar feed"

#. Translators: Label for a file dialog.
#: addon\globalPlugins\readFeeds\__init__.py:473
msgid "Open OPML file"
msgstr "Abrir archivo OPML"

#. Translators: Wildcards for a file dialog
#: addon\globalPlugins\readFeeds\__init__.py:475
msgid "OPML files (*.opml)|*.opml"
msgstr "Archivos OPML (*.opml)|*.opml"

#. Translators: Label of a button on the Feeds dialog.
#: addon\globalPlugins\readFeeds\__init__.py:502
msgid "Save As"
msgstr "Guardar como"

#. Translators: The label of the articles list in the articles dialog.
#: addon\globalPlugins\readFeeds\__init__.py:527
msgid "List of articles"
msgstr "Lista de artículos"

#. Translators: Presented when the current article does not have an associated title.
#: addon\globalPlugins\readFeeds\__init__.py:533
#: addon\globalPlugins\readFeeds\__init__.py:707
#: addon\globalPlugins\readFeeds\__init__.py:815
msgid "Unable to locate article title."
msgstr "No se encuentra el título del artículo."

#. Translators: The label of a button to open the selected article of a feed.
#: addon\globalPlugins\readFeeds\__init__.py:551
msgid "Open &web page of selected article."
msgstr "Abrir la página &web del artículo seleccionado."

#. Translators: The label of a button to show information of a feed article.
#: addon\globalPlugins\readFeeds\__init__.py:558
msgid "&About article..."
msgstr "Acerca del artículo..."

#. Translators: the label of a message box dialog.
#: addon\globalPlugins\readFeeds\__init__.py:581
#, python-brace-format
msgid "{}\n"
"{}\n"
"Do you want to copy article title and link to the clipboard?"
msgstr "{}\n"
"{}\n"
"¿Quieres copiar el título del artículo y el enlace al portapapeles?"

#. Translators: the title of a message box dialog.
#: addon\globalPlugins\readFeeds\__init__.py:584
msgid "Article information"
msgstr "Información del artículo"

#. Translators: label of a dialog.
#: addon\globalPlugins\readFeeds\__init__.py:605
msgid "&Search edit box after feeds list"
msgstr "Cuadro de edición de &búsqueda después de la lista de feeds"

#. Translators: label of a dialog.
#: addon\globalPlugins\readFeeds\__init__.py:610
msgid "&Show articles Date"
msgstr "Mostrar &fecha de los artículos"

#. Translators: Presented when the current article does not have an associated link.
#: addon\globalPlugins\readFeeds\__init__.py:719
msgid "Unable to locate article link."
msgstr "No se encuentra el enlace del artículo."

#. Translators: Label of a checkbox to choose if date should be presented for each feed.
#: addon\globalPlugins\readFeeds\__init__.py:803
msgid "Show date"
msgstr "Mostrar fecha"

#. Translators: Label for a checkbox to show buttons for copying to clipboard.
#: addon\globalPlugins\readFeeds\__init__.py:808
msgid "Show buttons to copy"
msgstr "Mostrar botones para copiar"

#. Translators: Label for a button to copy to clipboard.
#: addon\globalPlugins\readFeeds\__init__.py:819
msgid "Copy"
msgstr "Copiar"

#. Translators: the name of a menu item.
#: addon\globalPlugins\readFeeds\__init__.py:881
msgid "&Feeds..."
msgstr "&Feeds..."

#. Translators: message presented in input mode.
#: addon\globalPlugins\readFeeds\__init__.py:924
msgid "Activates the Feeds dialog of Read Feeds."
msgstr "Activa el diálogo Feeds de Read Feeds."

#. Translators: message presented in input mode.
#: addon\globalPlugins\readFeeds\__init__.py:931
#, python-format
msgid "Shows the %s settings."
msgstr "Muestra las opciones de %s."

#. Translators: message presented in input mode.
#: addon\globalPlugins\readFeeds\__init__.py:952
msgid "Refreshes the current feed and announces the most recent article title."
msgstr "Actualiza el feed actual y anuncia el título del artículo más reciente."

#. Translators: message presented in input mode.
#: addon\globalPlugins\readFeeds\__init__.py:963
msgid "Announces the title of the current article. Pressed two times, copies title and related link to the clipboard."
msgstr "Anuncia el título del artículo actual. Presionado dos veces, copia el título y el enlace relacionado al portapapeles."

#. Translators: message presented in input mode.
#: addon\globalPlugins\readFeeds\__init__.py:982
msgid "Announces the title of the next article."
msgstr "Anuncia el título del artículo siguiente."

#. Translators: message presented in input mode.
#: addon\globalPlugins\readFeeds\__init__.py:993
msgid "Announces the title of the previous article."
msgstr "Anuncia el título del artículo anterior."

#. Translators: message presented in input mode.
#: addon\globalPlugins\readFeeds\__init__.py:1004
msgid "Announces article link, when pressed two times, opens related web page."
msgstr "Anuncia el enlace del artículo, cuando se presiona dos veces, abre la Página web relacionada."

#. Translators: message presented in input mode.
#: addon\globalPlugins\readFeeds\__init__.py:1018
msgid "Copies title and related link of the current article to the clipboard."
msgstr "Copia el título y el enlace relacionado del actículo actual al portatapeles."

#. Add-on summary/title, usually the user visible name of the add-on
#. Translators: Summary/title for this add-on
#. to be shown on installation and add-on information found in add-on store
#: buildVars.py:21
msgid "Read Feeds"
msgstr "Read Feeds"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-on store
#: buildVars.py:24
msgid "Add-on for using NVDA as a feed reader."
msgstr "Complemento para el uso de NVDA como un lector de feeds."

